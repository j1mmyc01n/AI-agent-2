# ─────────────────────────────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────────────────────────────
# Full URL of your site (no trailing slash).
# On Netlify this is set automatically; on localhost use http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-min-32-chars-generate-with-openssl-rand-base64-32

# ─────────────────────────────────────────────────────────────────────
# Database (PostgreSQL required)
# ─────────────────────────────────────────────────────────────────────
# Standard PostgreSQL connection string.
# Get a free database from:
#   Neon    – https://console.neon.tech  (recommended for Netlify)
#   Supabase– https://supabase.com
#   Railway – https://railway.app
#
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# DIRECT_URL (optional but recommended for Neon with connection pooling)
# When DATABASE_URL is a pooled / PgBouncer URL, set DIRECT_URL to the
# unpooled connection string so Prisma migrations bypass the pool.
# For Neon: copy the "Direct connection" string from the dashboard.
# DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────────────
# AI Providers (at least one required for AI features)
# ─────────────────────────────────────────────────────────────────────
# Users can also add their own keys in Settings > AI Models.
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GROK_API_KEY=your-grok-api-key

# ─────────────────────────────────────────────────────────────────────
# GitHub OAuth (optional – enables GitHub login)
# ─────────────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: https://your-site.netlify.app/api/auth/callback/github
# GITHUB_ID=your-github-oauth-app-client-id
# GITHUB_SECRET=your-github-oauth-app-client-secret

# ─────────────────────────────────────────────────────────────────────
# Optional services
# ─────────────────────────────────────────────────────────────────────
# TAVILY_API_KEY=your-tavily-api-key          # web search in chat
# STRIPE_SECRET_KEY=your-stripe-secret-key   # future billing
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...  # future billing
